{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "runtime": "nodejs20.x"
        }
    },
    "routes": [
        {
            "src": "^/api/(.*)$",
            "dest": "/api/index.js"
        },
        {
            "src": "^/$",
            "dest": "/cg.html"
        },
        {
            "src": "^/admin$",
            "dest": "/admin.html"
        },
        {
            "src": "^/admin-users$",
            "dest": "/admin-users.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "^/(.*)$",
            "dest": "/cg.html"
        }
    ]
}