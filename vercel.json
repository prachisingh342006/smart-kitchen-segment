{
    "version": 2,
    "routes": [
        {
            "src": "^/api/(.*)$",
            "dest": "/api/index.js"
        },
        {
            "src": "^/$",
            "dest": "/cg.html"
        },
        {
            "src": "^/admin$",
            "dest": "/admin.html"
        },
        {
            "src": "^/admin-users$",
            "dest": "/admin-users.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "^/(.*)$",
            "dest": "/cg.html"
        }
    ]
}